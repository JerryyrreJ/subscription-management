# Browser-visible Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Preferred server-only Supabase names. Functions also accept the VITE URL and
# legacy SUPABASE_SERVICE_ROLE_KEY during migration.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Browser feature detection only. Checkout trusts STRIPE_PRICE_ID below and
# does not accept a Price ID from the browser.
VITE_STRIPE_PUBLISHABLE_KEY=

# Server-only Stripe configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
SITE_URL=http://localhost:8888

# Public API limits. All logged-in users can create API keys; premium users get
# higher defaults.
API_FREE_RATE_LIMIT_PER_HOUR=60
API_PREMIUM_RATE_LIMIT_PER_HOUR=1000
API_FREE_ACTIVE_KEYS=1
API_PREMIUM_ACTIVE_KEYS=5
API_FAILED_AUTH_RATE_LIMIT_PER_HOUR=300
API_RATE_LIMIT_RETENTION_HOURS=48

# AI capture (optional). Leave OPENROUTER_API_KEY/ANTHROPIC_API_KEY unset to
# disable the feature — the "Add" flow then falls back to the manual form.
# OpenRouter is the low-cost default; Anthropic remains supported via
# AI_PROVIDER=anthropic + ANTHROPIC_API_KEY.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Subscription Manager
ANTHROPIC_API_KEY=
AI_PROVIDER=openrouter
AI_MODEL=google/gemini-2.5-flash-lite
AI_FALLBACK_MODELS=google/gemini-2.5-flash
# Per-user daily parse quota (free vs premium) — the primary volume control.
AI_FREE_DAILY_PARSES=20
AI_PREMIUM_DAILY_PARSES=200
# Per-request input caps (characters of text; decoded bytes of an image).
AI_MAX_INPUT_CHARS=20000
AI_MAX_IMAGE_BYTES=4194304
# Workspace-wide monthly budget breaker (USD) + the per-million-token prices used
# to estimate spend. Defaults match Gemini 2.5 Flash-Lite via OpenRouter.
AI_MONTHLY_BUDGET_USD=50
AI_INPUT_USD_PER_MTOK=0.1
AI_OUTPUT_USD_PER_MTOK=0.4
