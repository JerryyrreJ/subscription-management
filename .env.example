# Browser-visible Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Preferred server-only Supabase names. Functions also accept the VITE URL and
# legacy SUPABASE_SERVICE_ROLE_KEY during migration.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Browser feature detection only. Checkout trusts STRIPE_PRICE_ID below and
# does not accept a Price ID from the browser.
VITE_STRIPE_PUBLISHABLE_KEY=

# Server-only Stripe configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
SITE_URL=http://localhost:8888

# Public API limits. All logged-in users can create API keys; premium users get
# higher defaults.
API_FREE_RATE_LIMIT_PER_HOUR=60
API_PREMIUM_RATE_LIMIT_PER_HOUR=1000
API_FREE_ACTIVE_KEYS=1
API_PREMIUM_ACTIVE_KEYS=5
API_FAILED_AUTH_RATE_LIMIT_PER_HOUR=300
API_RATE_LIMIT_RETENTION_HOURS=48
