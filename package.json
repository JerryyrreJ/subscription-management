{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "1.8.7",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "netlify dev",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:app && npm run typecheck:functions",
    "typecheck:app": "tsc -p tsconfig.app.json",
    "typecheck:functions": "tsc -p tsconfig.functions.json",
    "test": "node --import tsx --test tests/utils/*.test.ts",
    "test:functions": "node --import tsx --test tests/functions/*.test.ts",
    "db:start": "supabase start -x studio,imgproxy,edge-runtime,logflare,vector,supavisor",
    "db:verify": "npm run db:start && supabase db reset --local && supabase db lint --local --fail-on error && supabase test db --local",
    "check": "npm run typecheck && npm run lint && npm test && npm run test:functions && npm run build",
    "preview": "vite preview",
    "test:notifications": "tsx scripts/test-scheduled-function-v2.ts"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.2",
    "@sparticuz/chromium": "^141.0.0",
    "@supabase/supabase-js": "^2.57.4",
    "chromium-bidi": "^11.0.1",
    "i18next": "^26.0.3",
    "lucide-react": "^0.344.0",
    "playwright-core": "^1.57.0",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "recharts": "^3.2.1",
    "stripe": "^19.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/node": "22.19.21",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "9.39.3",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.48",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "8.61.0",
    "vite": "^7.3.1"
  }
}
